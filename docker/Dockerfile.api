# API image: lightweight, no OpenFOAM. Enqueues jobs and serves results.
FROM python:3.12-slim

ENV AIRFOILFOAM_DATA_DIR=/data/airfoilfoam \
    PYTHONUNBUFFERED=1

WORKDIR /app
COPY pyproject.toml README.md ./
COPY src ./src
RUN pip install --no-cache-dir .

RUN mkdir -p /data/airfoilfoam
EXPOSE 8000

CMD ["uvicorn", "airfoilfoam.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
