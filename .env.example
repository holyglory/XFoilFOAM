# Copy to .env and adjust. All variables are optional (defaults shown).
AIRFOILFOAM_DATA_DIR=/data/airfoilfoam
AIRFOILFOAM_OPENFOAM_IMAGE=opencfd/openfoam-default:2406
# 'docker' runs a container per OpenFOAM command (host with the image only);
# 'local' runs solvers directly (inside the OpenFOAM-based worker container).
AIRFOILFOAM_OPENFOAM_RUNNER=docker
AIRFOILFOAM_OPENFOAM_BASHRC=/usr/lib/openfoam/openfoam2406/etc/bashrc
AIRFOILFOAM_REDIS_URL=redis://localhost:6379/0
AIRFOILFOAM_CASE_CONCURRENCY=4
AIRFOILFOAM_SOLVER_PROCESSES=1
AIRFOILFOAM_SOLVER_TIMEOUT=7200
