# Copy to .env and adjust. All variables are optional (defaults shown).
AIRFOILFOAM_DATA_DIR=/data/airfoilfoam
AIRFOILFOAM_CACHE_DIR=/data/airfoilfoam/cache
AIRFOILFOAM_CACHE_MAX_GB=20
AIRFOILFOAM_EVIDENCE_BUCKET=
AIRFOILFOAM_EVIDENCE_OBJECT_PREFIX=solver-evidence/v1
AIRFOILFOAM_EVIDENCE_ZSTD_LEVEL=10
AIRFOILFOAM_EVIDENCE_REMOTE_ONLY=false
AIRFOILFOAM_EVIDENCE_HYDRATION_CACHE_DIR=/data/airfoilfoam/evidence-hydration-cache
AIRFOILFOAM_EVIDENCE_HYDRATION_CACHE_MAX_GB=50
AIRFOILFOAM_EVIDENCE_HYDRATION_CACHE_TTL_SECONDS=86400
AIRFOILFOAM_EVIDENCE_GCS_TIMEOUT_SECONDS=900
# The default implementation is OpenFOAM from OpenCFD, release 2606. These
# five fields form the exact request/worker handshake. A numerics revision is
# changed only when generated cases/defaults can change numerical results;
# adapter-contract changes are wire-protocol changes.
AIRFOILFOAM_ENGINE_FAMILY=openfoam
AIRFOILFOAM_ENGINE_DISTRIBUTION=opencfd
AIRFOILFOAM_ENGINE_VERSION=2606
AIRFOILFOAM_ENGINE_NUMERICS_REVISION=1
AIRFOILFOAM_ENGINE_ADAPTER_CONTRACT_VERSION=1
AIRFOILFOAM_ENGINE_SOURCE_REVISION=481094fdf34f11ed6d0d603ee59a858a0124236d
# The gateway routes only exact identities listed here. Registered adapters
# that are absent remain visible but reject submissions before queueing.
AIRFOILFOAM_ENABLED_ENGINE_KEYS=openfoam:opencfd:2606:numerics-1:adapter-1
# OpenFOAM Foundation 14 is opt-in. Do not uncomment only one of these lines:
# the profile starts its isolated worker, and the gateway key makes it
# routable. Its database execution pool still starts disabled and is enabled
# from Admin > Queue > Engine only after the worker is healthy.
# COMPOSE_PROFILES=foundation14
# AIRFOILFOAM_ENABLED_ENGINE_KEYS=openfoam:opencfd:2606:numerics-1:adapter-1,openfoam:foundation:14:numerics-1:adapter-1
# Optional provenance for the final locally built worker images (not merely
# their upstream base images). Leave blank when the digest is not known.
OPENCFD2606_IMAGE_DIGEST=
# Set to 1 only while the guarded deploy workflow is draining/recovering the
# one-time OpenCFD 2406 -> 2606 runtime cutover.
OPENCFD2606_CUTOVER_PENDING=0
# Set only by the guarded maintenance workflow after the exact live worker,
# production canaries, campaign generation, and sweeper restoration succeed.
# A fresh deployment intentionally starts uncertified and requires one
# authenticated `rebuild-engine.sh` activation run.
OPENCFD2606_CUTOVER_COMPLETE=0
# Atomically written with the canary attestation id. Once present, every
# engine and control-plane deploy must reproduce this exact bucket, object
# prefix, Zstandard level, and remote-only evidence disposition.
OPENCFD2606_CERTIFIED_EVIDENCE_CONTRACT_SHA256=
# Durable recovery fields owned by the guarded cutover. A receipt-expected
# value of 1 without its external state-file receipt is a hard stop.
OPENCFD2606_CANARY_ATTESTATION_ID=
OPENCFD2606_CANARY_RECEIPT_EXPECTED=0
# Exact promoted source bound atomically while a recovery workflow is pending.
# Both remain empty in pristine and terminal states.
OPENCFD2606_CUTOVER_SOURCE_REVISION=
OPENCFD2606_CUTOVER_SOURCE_TREE_SHA256=
# The guarded cutover records whether sweeper was running before it paused so
# a failed/retried cutover restores the original state instead of guessing.
OPENCFD2606_CUTOVER_SWEEPER_WAS_RUNNING=
FOUNDATION14_IMAGE_DIGEST=
AIRFOILFOAM_OPENFOAM_IMAGE=opencfd/openfoam-run:2606@sha256:4229997e74defb81548222d511b8e3b95b98305e5df41b8e88b031813fe47eeb
# 'docker' runs a container per OpenFOAM command (host with the image only);
# 'local' runs solvers directly (inside the OpenFOAM-based worker container).
AIRFOILFOAM_OPENFOAM_RUNNER=docker
AIRFOILFOAM_OPENFOAM_BASHRC=/usr/lib/openfoam/openfoam2606/etc/bashrc
AIRFOILFOAM_CELERY_QUEUE=openfoam-opencfd-2606
AIRFOILFOAM_REDIS_URL=redis://localhost:6379/0
AIRFOILFOAM_WORKER_CPU_BUDGET=18
AIRFOILFOAM_CASE_CONCURRENCY=18
AIRFOILFOAM_CELERY_CONCURRENCY=18
# Multi-worker Compose overrides this with one shared engine_runtime volume.
AIRFOILFOAM_CPU_TOKEN_STATE_PATH=/tmp/airfoilfoam-cpu-tokens.json
AIRFOILFOAM_SOLVER_PROCESSES=1
AIRFOILFOAM_SOLVER_TIMEOUT=7200
AIRFOILFOAM_RANS_SOLVER_TIMEOUT=1200
AIRFOILFOAM_RANS_MAX_ITERATIONS=600

# ===== Airfoils.Pro Node control-plane (apps/api, apps/web, apps/sweeper, packages/db) =====
# Postgres connection. compose publishes Postgres on host port 5544 (avoids clashing
# with a local 5432); inside compose, services use host 'postgres' on 5432.
DATABASE_URL=postgres://aerodb:aerodb@localhost:5544/aerodb
# Base URL of the Python CFD solver service (FastAPI). compose host is 'api'.
ENGINE_URL=http://localhost:8000
# Shared CFD data volume the Python service writes images/results into (read by the media store).
MEDIA_DIR=/data/airfoilfoam
# Fastify control-plane API.
API_PORT=4000
API_HOST=0.0.0.0
# Where the Next.js app reaches the Node API (server-side render fetches).
API_URL=http://localhost:4000
# Browser-visible API base (same value in dev).
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Admin console auth ---
# Auth is OFF in dev (NODE_ENV != production) and ON in prod. Override for testing:
#   ADMIN_AUTH_REQUIRED=true  forces auth even in dev
#   ADMIN_AUTH_DISABLED=true  forces open access even in prod
# Password auth is available only when ADMIN_PASSWORD is set.
ADMIN_EMAIL=admin@airfoils.pro
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie (set a long random value in prod).
ADMIN_SESSION_SECRET=aero-dev-insecure-secret-change-me
# Google OAuth admin auth. In prod, set these and configure the Google OAuth app
# redirect URI to https://airfoils.pro/api/admin/oauth/google/callback.
ADMIN_GOOGLE_CLIENT_ID=
ADMIN_GOOGLE_CLIENT_SECRET=
ADMIN_GOOGLE_ALLOWED_DOMAIN=vr.ae
ADMIN_GOOGLE_REDIRECT_URI=
ADMIN_PUBLIC_ORIGIN=
