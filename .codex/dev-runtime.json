{
  "name": "aerodb",
  "servers": [
    {
      "name": "api",
      "role": "api",
      "port": 4000,
      "argv": [
        "corepack",
        "pnpm",
        "--filter",
        "@aerodb/api",
        "dev"
      ],
      "health_url": "http://127.0.0.1:{port}/health",
      "env": [
        "CI=true",
        "DATABASE_URL=postgres://aerodb:aerodb@127.0.0.1:5544/aerodb",
        "API_HOST=127.0.0.1",
        "API_PORT=4000",
        "ENGINE_URL=http://127.0.0.1:8000",
        "MEDIA_DIR=data/airfoilfoam",
        "ENGINE_EXPECTED_BUILD_ID=dev-20260704-batch-cache"
      ]
    },
    {
      "name": "web",
      "role": "web",
      "port": 3004,
      "argv": [
        "/bin/sh",
        "-lc",
        "rm -rf apps/web/.next && exec corepack pnpm --filter @aerodb/web exec next dev -H 127.0.0.1 -p {port}"
      ],
      "health_url": "http://127.0.0.1:{port}/health",
      "env": [
        "CI=true",
        "API_URL=http://127.0.0.1:4000",
        "NEXT_PUBLIC_API_URL=http://127.0.0.1:4000",
        "NEXT_TELEMETRY_DISABLED=1"
      ]
    },
    {
      "name": "sweeper",
      "role": "worker",
      "argv": [
        "corepack",
        "pnpm",
        "--filter",
        "@aerodb/sweeper",
        "dev"
      ],
      "env": [
        "CI=true",
        "DATABASE_URL=postgres://aerodb:aerodb@127.0.0.1:5544/aerodb",
        "ENGINE_URL=http://127.0.0.1:8000",
        "MEDIA_DIR=data/airfoilfoam"
      ]
    }
  ],
  "dependencies": [
    {
      "type": "docker",
      "name": "database",
      "container": "aerodb-pg",
      "ports": [
        {
          "host": "127.0.0.1",
          "port": 5544
        }
      ]
    },
    {
      "type": "docker",
      "name": "openfoam-api",
      "container": "xfoilfoam-api-1",
      "ports": [
        {
          "host": "127.0.0.1",
          "port": 8000
        }
      ]
    },
    {
      "type": "docker",
      "name": "openfoam-worker",
      "container": "xfoilfoam-worker-1"
    },
    {
      "type": "docker",
      "name": "openfoam-redis",
      "container": "xfoilfoam-redis-1"
    }
  ],
  "health_checks": [
    {
      "name": "api-ready",
      "url": "http://127.0.0.1:4000/health",
      "expect_status": 200
    },
    {
      "name": "web-ready",
      "url": "http://127.0.0.1:3004/health",
      "expect_status": 200
    },
    {
      "name": "web-detail-ready",
      "url": "http://127.0.0.1:3004/airfoils/ag24",
      "expect_status": 200
    },
    {
      "name": "openfoam-ready",
      "url": "http://127.0.0.1:8000/health",
      "expect_status": 200,
      "expect_text": "ok"
    }
  ],
  "docker": {
    "compose_files": [
      "docker-compose.yml"
    ],
    "services": [
      "redis",
      "api",
      "worker"
    ]
  }
}
